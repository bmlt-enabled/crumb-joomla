<?xml version="1.0"?>
<ruleset name="crumb-joomla">
    <description>PSR-12 with light project tweaks for the Crumb Joomla package.</description>

    <file>packages</file>
    <file>tests</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <rule ref="PSR12">
        <!-- Every Joomla extension file pairs a `\defined('_JEXEC') or die;`
             guard (side effect) with a namespace + class declaration in the
             same file — that's the framework convention, not a smell.
             Joomla core itself opts out of this rule. -->
        <exclude name="PSR1.Files.SideEffects"/>
    </rule>
</ruleset>
